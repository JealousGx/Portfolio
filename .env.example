NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=your@email.com

# Chat widget (Groq — free tier, get a key at https://console.groq.com/keys)
GROQ_API_KEY=

# Chat widget meeting booking (optional — omit to disable booking, bot falls back to "email me")
# API key from cal.com Settings > Developer > API Keys. The booking page URL itself
# is in data/resume.tsx (DATA.bookingUrl) — it's public, not a secret.
CAL_COM_API_KEY=

# Keystatic GitHub mode (production only)
# Create at: https://github.com/settings/applications/new
# Homepage URL: https://jealous.dev
# Callback URL: https://jealous.dev/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=